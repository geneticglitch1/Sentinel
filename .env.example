# Secrets for Sentinel. Copy to .env and fill in. Never commit the real .env.

# Claude (used by the Agent SDK for deploy/chat). Get one from the Anthropic console.
ANTHROPIC_API_KEY=sk-ant-...

# SSH private key that reaches the firewall / Proxmox / docker host.
# In the cowork setup this was the `claude-cowork-audit` key.
SENTINEL_SSH_KEY_PATH=~/.ssh/id_ed25519

# OPNsense API key/secret (System → Access → Users → <user> → API keys).
# Needed only for firewall_rule / ids_set_mode (REST). IDS/CrowdSec status works over SSH.
SENTINEL_OPNSENSE_API_KEY=
SENTINEL_OPNSENSE_API_SECRET=

# Proxmox API token (optional). Without it, Sentinel falls back to qm/pct over SSH.
# Format: "user@realm!tokenname"  e.g.  root@pam!sentinel
SENTINEL_PROXMOX_TOKEN_ID=
SENTINEL_PROXMOX_TOKEN_SECRET=

# For docker-compose: path on the host to the SSH key to mount into the agent.
SSH_KEY=~/.ssh/id_ed25519
